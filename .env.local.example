# Wapate — Supabase environment variables
# ─────────────────────────────────────────────
# 1. Copy this file:  copy .env.local.example .env.local
# 2. Fill in values from: Supabase Dashboard → Project Settings → API
# 3. Restart dev server: npm run dev

# Required — your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Required — public anon key (safe for browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — used for email confirmation redirects (local: http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=https://wapate.no
